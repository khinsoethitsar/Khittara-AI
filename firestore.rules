rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global safety net: Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helper Functions (Pillar 3 & 4)
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ["minthitsar125226@gmail.com", "freemoneyaungthitsar@gmail.com"] && 
        request.auth.token.email_verified == true
      );
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // --- SESSIONS ---
    function isValidSession(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'messages', 'updatedAt']) &&
             data.keys().size() == 5 &&
             isValidId(data.id) &&
             isValidId(data.userId) &&
             data.title is string && data.title.size() <= 1000 &&
             data.messages is list && data.messages.size() <= 1000 &&
             (data.updatedAt is timestamp || data.updatedAt is string);
    }

    match /sessions/{sessionId} {
      allow get: if isSignedIn() && (request.auth.uid == existing().userId || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      
      allow create: if isSignedIn() && 
                      isValidSession(incoming()) && 
                      incoming().userId == request.auth.uid;
                      
      allow update: if isSignedIn() && 
                      isValidSession(incoming()) &&
                      request.auth.uid == existing().userId &&
                      incoming().userId == existing().userId;
                      
      allow delete: if isSignedIn() && (request.auth.uid == existing().userId || isAdmin());
    }

    // --- USERS ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             (data.updatedAt is timestamp || data.updatedAt is string);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      
      allow update: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      (incoming().get('role', 'user') == existing().get('role', 'user') || isAdmin());
    }

    // --- CREATOR MEMORIES ---
    function isValidCreatorMemory(data) {
      return data.keys().hasAll(['id', 'fact', 'source', 'timestamp']) &&
             data.keys().size() == 4 &&
             isValidId(data.id) &&
             data.fact is string && data.fact.size() >= 1 && data.fact.size() <= 10000 &&
             data.source in ['guest', 'creator'] &&
             (data.timestamp is timestamp || data.timestamp == request.time);
    }

    match /creator_memories/{memoryId} {
      allow read: if true; 
      
      allow create: if (isAdmin() || (isSignedIn() && incoming().source == 'guest')) &&
                      isValidCreatorMemory(incoming());
                      
      allow update, delete: if isAdmin();
    }

    // --- USER MEMORIES ---
    match /memories/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // --- LIVE CHAT ---
    function isValidLiveChat(data) {
      return data.keys().hasAll(['message', 'senderId', 'senderName', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.message is string && data.message.size() >= 1 && data.message.size() <= 2000 &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    match /live_chat/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidLiveChat(incoming());
      allow delete: if isAdmin();
    }

    // --- TASKS ---
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == existing().userId;
      allow delete: if isSignedIn() && (request.auth.uid == existing().userId || isAdmin());
    }
  }
}
